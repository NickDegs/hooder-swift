default_platform :ios

COMMON_XCARGS = [
  "CODE_SIGN_STYLE=Manual",
  "CODE_SIGN_IDENTITY='Apple Distribution'",
  "DEVELOPMENT_TEAM=#{ENV.fetch('ASC_TEAM_ID', 'AC4KJAUPL4')}",
  "TARGETED_DEVICE_FAMILY=1,2",
  "IPHONEOS_DEPLOYMENT_TARGET=16.0",
  "ENABLE_BITCODE=NO",
  "ONLY_ACTIVE_ARCH=NO",
  "ARCHS=arm64",
  "SWIFT_COMPILATION_MODE=wholemodule",
  "GCC_OPTIMIZATION_LEVEL=s",
  "MAPBOX_TOKEN=#{ENV.fetch('MAPBOX_TOKEN', '')}",
].join(" ")

platform :ios do

  desc "Build + TestFlight'a yükle"
  lane :release do
    api_key = asc_key

    # CI adımı profili oluşturdu: /tmp/fl-certs/*.mobileprovision
    # Yoksa get_provisioning_profile ile indir
    profile_file = Dir["/tmp/fl-certs/*.mobileprovision"].first
    if profile_file.nil?
      get_provisioning_profile(
        app_identifier: "app.realvirtuality.landlord",
        api_key:        api_key,
        output_path:    "/tmp/fl-certs",
        force:          true,
      )
      profile_file = Dir["/tmp/fl-certs/*.mobileprovision"].first
    end

    # Profil UUID'sini oku
    profile_uuid = ENV["PROFILE_UUID"]
    if profile_uuid.nil? || profile_uuid.empty?
      profile_uuid = lane_context[SharedValues::SIGH_UUID]
    end
    if profile_uuid.nil? || profile_uuid.empty?
      require "plist"
      plist_content = `security cms -D -i "#{profile_file}" 2>/dev/null`
      profile_uuid  = Plist.parse_xml(plist_content)["UUID"]
    end

    # Profili Xcode'un arayacağı yere kur
    install_provisioning_profile(path: profile_file)

    # Xcode projesini manuel signing için ayarla
    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  "Hooder.xcodeproj",
      team_id:               ENV.fetch("ASC_TEAM_ID", "AC4KJAUPL4"),
      code_sign_identity:    "Apple Distribution",
    )

    update_project_provisioning(
      xcodeproj:           "Hooder.xcodeproj",
      profile:             profile_file,
      target_filter:       "Hooder",
      build_configuration: "Release",
    )

    build_app(
      project:           "Hooder.xcodeproj",
      scheme:            "Hooder",
      configuration:     "Release",
      export_method:     "app-store",
      output_directory:  "./build",
      output_name:       "Hooder.ipa",
      xcargs:            COMMON_XCARGS,
      export_options: {
        method:               "app-store",
        signingStyle:         "manual",
        signingCertificate:   "Apple Distribution",
        stripSwiftSymbols:    true,
        thinning:             "<thin-for-all-variants>",
        provisioningProfiles: {
          "app.realvirtuality.landlord" => profile_uuid,
        },
      },
      build_path:        "./build",
      derived_data_path: "./build/DerivedData",
    )

    unless ENV["FL_SKIP_UPLOAD"] == "true"
      upload_to_testflight(
        api_key:                           api_key,
        ipa:                               "./build/Hooder.ipa",
        skip_waiting_for_build_processing: false,
        changelog:                         ENV.fetch("RELEASE_NOTES", "Yeni güncelleme."),
      )
    end
  end

  desc "Distribute to external TestFlight testers"
  lane :distribute do
    api_key = asc_key
    upload_to_testflight(
      api_key:                           api_key,
      ipa:                               "./build/Hooder.ipa",
      distribute_external:               true,
      notify_external_testers:           true,
      changelog:                         ENV.fetch("RELEASE_NOTES", "Yeni güncelleme."),
      beta_app_description:              "Hooder — Gerçek zamanlı emlak yatırım oyunu. 384 mülk, 7 şehir, 3D Mapbox harita, iOS 26 Liquid Glass.",
      beta_app_feedback_email:           "daclen100@gmail.com",
      demo_account_required:             false,
      reject_build_waiting_for_review:   false,
      skip_waiting_for_build_processing: false,
    )
  end

  private_lane :asc_key do
    app_store_connect_api_key(
      key_id:      ENV.fetch("ASC_KEY_ID"),
      issuer_id:   ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_API_KEY"),
      in_house:    false,
    )
  end

end
